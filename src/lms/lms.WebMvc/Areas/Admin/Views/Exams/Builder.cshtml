@{
    ViewData["Title"] = "Thiết kế bài thi";
    var examId = ViewData["ExamId"] ?? 0;
}

<div class="page-header" data-exam-builder-id="@examId">
    <div class="page-header-main">
        <nav class="page-breadcrumb" aria-label="Breadcrumb">
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" data-i18n="exams.builderPage.breadcrumbRoot">Quản trị</a>
            <span>/</span>
            <a asp-area="Admin" asp-controller="Exams" asp-action="Index" data-i18n="exams.builderPage.breadcrumbManagement">Quản lý bài thi</a>
            <span>/</span>
            <span data-i18n="exams.builderPage.breadcrumbCurrent">Thiết kế</span>
        </nav>
        <h1 class="page-title" data-exam-builder-title data-i18n="exams.builderPage.title">Thiết kế bài thi</h1>
        <p class="page-muted u-mb-0" data-i18n="exams.builderPage.pageSubtitle">Cấu hình thông tin cơ bản của bài thi trước khi lựa chọn câu hỏi và giao bài thi.</p>
    </div>
    <div class="page-header-actions">
        <a class="app-button app-button-secondary" asp-area="Admin" asp-controller="Exams" asp-action="Index" data-i18n="exams.builderPage.backToExams">Quay lại bài thi</a>
        <button class="app-button app-button-primary" type="button" data-exam-builder-action="save" data-i18n="exams.builderPage.saveGeneral">Lưu thông tin chung</button>
    </div>
</div>

<section class="exam-builder-tabs" aria-label="Các bước thiết kế bài thi" data-i18n-aria="exams.builderPage.tabsAria">
    <button class="exam-builder-tab active" type="button" data-exam-builder-tab="general" data-i18n="exams.builderPage.tabGeneral">Thông tin chung</button>
    <button class="exam-builder-tab" type="button" data-exam-builder-tab="questions" data-i18n="exams.builderPage.tabQuestions">Câu hỏi</button>
    <button class="exam-builder-tab" type="button" data-exam-builder-tab="assignment" data-i18n="exams.builderPage.tabAssignment">Giao bài thi</button>
    <button class="exam-builder-tab" type="button" data-exam-builder-tab="settings" data-i18n="exams.builderPage.tabSettings">Cài đặt</button>
</section>

<section class="exam-builder-layout" data-exam-builder-panel="general">
    <article class="app-card app-animate-slide-up">
        <div class="app-card-header">
            <h2 class="app-card-title" data-i18n="exams.builderPage.cardTitleGeneral">Thông tin chung</h2>
            <p class="app-card-subtitle" data-i18n="exams.builderPage.cardSubtitleGeneral">Tên, mô tả, thời lượng, điểm đạt và chính sách xem lại.</p>
        </div>
        <form class="app-card-body admin-user-form exam-builder-form" id="examGeneralForm" novalidate>
            <label class="auth-field"><span data-i18n="exams.builderPage.labelExamName">Tên bài thi</span>
                <input class="app-input" name="name" type="text" autocomplete="off" />
                <span class="auth-error" data-exam-builder-error="name"></span>
            </label>

            <label class="auth-field"><span data-i18n="exams.builderPage.labelDescription">Mô tả</span>
                <textarea class="app-input admin-course-textarea" name="description" rows="4"></textarea>
                <span class="auth-error" data-exam-builder-error="description"></span>
            </label>

            <div class="admin-user-form-grid">
                <label class="auth-field"><span data-i18n="exams.builderPage.labelDurationMinutes">Thời lượng (phút)</span>
                    <input class="app-input" name="durationMinutes" type="number" min="5" step="1" />
                    <span class="auth-error" data-exam-builder-error="durationMinutes"></span>
                </label>
                <label class="auth-field"><span data-i18n="exams.builderPage.labelPassScore">Điểm đạt (trên 100)</span>
                    <input class="app-input" name="passScore" type="number" min="1" max="100" step="1" />
                    <span class="auth-error" data-exam-builder-error="passScore"></span>
                </label>
            </div>

            <label class="auth-field"><span data-i18n="exams.builderPage.labelReviewPolicy">Chính sách xem lại</span>
                <select class="app-select" name="reviewMode">
                    <option value="" data-i18n="exams.builderPage.optionSelectReviewPolicy">Chọn chính sách xem lại</option>
                    <option value="FULL_REVIEW" data-i18n="exams.builderPage.optionReviewFull">Xem toàn bộ</option>
                    <option value="RESULT_ONLY" data-i18n="exams.builderPage.optionReviewResultOnly">Chỉ xem kết quả</option>
                    <option value="ANSWER_ONLY" data-i18n="exams.builderPage.optionReviewAnswerOnly">Chỉ xem đáp án</option>
                    <option value="NO_REVIEW" data-i18n="exams.builderPage.optionReviewNo">Không cho xem lại</option>
                </select>
                <span class="auth-error" data-exam-builder-error="reviewMode"></span>
            </label>
        </form>
    </article>

    <aside class="exam-builder-side">
        <article class="app-card">
            <div class="app-card-header">
                <h2 class="app-card-title" data-i18n="exams.builderPage.cardTitleSummary">Tổng quan</h2>
                <p class="app-card-subtitle" data-i18n="exams.builderPage.cardSubtitleSummary">Xem trước trực quan của tab thông tin chung.</p>
            </div>
            <div class="app-card-body">
                <div class="admin-summary-line">
                    <span data-i18n="exams.builderPage.summaryStatus">Trạng thái</span>
                    <strong data-exam-builder-summary="status">Draft</strong>
                </div>
                <div class="admin-summary-line u-mt-4">
                    <span data-i18n="exams.builderPage.summaryDuration">Thời lượng</span>
                    <strong data-exam-builder-summary="duration">--</strong>
                </div>
                <div class="admin-summary-line u-mt-4">
                    <span data-i18n="exams.builderPage.summaryPassScore">Điểm đạt</span>
                    <strong data-exam-builder-summary="passScore">--</strong>
                </div>
                <div class="admin-summary-line u-mt-4">
                    <span data-i18n="exams.builderPage.summaryReview">Xem lại</span>
                    <strong data-exam-builder-summary="reviewMode">--</strong>
                </div>
            </div>
        </article>

        <article class="app-card u-mt-4">
            <div class="app-card-header">
                <h2 class="app-card-title" data-i18n="exams.builderPage.cardTitleNextTabs">Các tab tiếp theo</h2>
                <p class="app-card-subtitle" data-i18n="exams.builderPage.cardSubtitleQueued">Các tab này sẽ hoạt động sau khi cấu hình thông tin chung.</p>
            </div>
            <div class="app-card-body">
                <div class="app-empty-state">
                    <div class="app-empty-icon" aria-hidden="true">Q</div>
                    <h3 class="app-empty-title" data-i18n="exams.builderPage.emptyTitleQuestionsNext">Tiếp theo: Câu hỏi</h3>
                    <p class="app-empty-copy" data-i18n="exams.builderPage.emptyCopyQuestionsNext">Tính năng chọn câu hỏi thủ công và quy tắc ngẫu nhiên sẽ được kích hoạt sau khi lưu thông tin chung.</p>
                </div>
            </div>
        </article>
    </aside>
</section>

<section class="exam-builder-layout u-hidden" data-exam-builder-panel="questions">
    <article class="app-card app-animate-slide-up">
        <div class="app-card-header">
            <div class="admin-card-header-row">
                <div>
                    <h2 class="app-card-title" data-i18n="exams.builderPage.cardTitleQuestionsTab">Câu hỏi</h2>
                    <p class="app-card-subtitle" data-i18n="exams.builderPage.cardSubtitleQuestionsTab">Chọn câu hỏi thủ công hoặc tạo quy tắc ngẫu nhiên.</p>
                </div>
                <span class="app-badge app-badge-info" data-exam-question-count>-- đã chọn</span>
            </div>
        </div>
        <div class="app-card-body">
            <div class="app-filter-bar admin-user-filter">
                <label class="visually-hidden" for="examQuestionSearch" data-i18n="exams.builderPage.labelQuestionSearch">Tìm kiếm câu hỏi</label>
                <input class="app-input" id="examQuestionSearch" type="search" placeholder="Tìm nội dung câu hỏi..." data-exam-question-filter="search" data-i18n-placeholder="exams.builderPage.placeholderQuestionSearch" />

                <label class="visually-hidden" for="examQuestionCategory" data-i18n="exams.builderPage.labelQuestionCategory">Danh mục</label>
                <select class="app-select" id="examQuestionCategory" data-exam-question-filter="category">
                    <option value="" data-i18n="exams.builderPage.optionAllCategories">Tất cả danh mục</option>
                </select>

                <label class="visually-hidden" for="examQuestionDifficulty" data-i18n="exams.builderPage.labelQuestionDifficulty">Độ khó</label>
                <select class="app-select" id="examQuestionDifficulty" data-exam-question-filter="difficulty">
                    <option value="" data-i18n="exams.builderPage.optionAllDifficulty">Tất cả độ khó</option>
                    <option value="Easy" data-i18n="exams.builderPage.optionEasy">Dễ</option>
                    <option value="Medium" data-i18n="exams.builderPage.optionMedium">Trung bình</option>
                    <option value="Hard" data-i18n="exams.builderPage.optionHard">Khó</option>
                </select>

                <button class="app-button app-button-secondary" type="button" data-exam-question-action="clear-filters" data-i18n="exams.builderPage.buttonClear">Xóa bộ lọc</button>
            </div>

            <div class="app-table-wrapper u-mt-4">
                <table class="app-table table admin-question-table">
                    <thead>
                        <tr>
                            <th scope="col" data-i18n="exams.builderPage.tableHeaderSelect">Chọn</th>
                            <th scope="col" data-i18n="exams.builderPage.tableHeaderQuestion">Câu hỏi</th>
                            <th scope="col" data-i18n="exams.builderPage.tableHeaderCategory">Danh mục</th>
                            <th scope="col" data-i18n="exams.builderPage.tableHeaderDifficulty">Độ khó</th>
                            <th scope="col" data-i18n="exams.builderPage.tableHeaderType">Thể loại</th>
                            <th scope="col" data-i18n="exams.builderPage.tableHeaderScore">Điểm</th>
                        </tr>
                    </thead>
                    <tbody id="examQuestionRows">
                        <tr>
                            <td colspan="6">
                                <div class="app-loading">
                                    <span class="app-spinner" aria-hidden="true"></span>
                                    <span data-i18n="exams.builderPage.loadingQuestions">Đang tải câu hỏi...</span>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </article>

    <aside class="exam-builder-side">
        <article class="app-card">
            <div class="app-card-header">
                <h2 class="app-card-title" data-i18n="exams.builderPage.cardTitleSelectedSummary">Tổng hợp lựa chọn</h2>
                <p class="app-card-subtitle" data-i18n="exams.builderPage.cardSubtitleSelectedSummary">Xem trước câu hỏi thủ công và quy tắc ngẫu nhiên.</p>
            </div>
            <div class="app-card-body">
                <div class="admin-summary-line">
                    <span data-i18n="exams.builderPage.summaryManualQuestions">Câu hỏi thủ công</span>
                    <strong data-exam-question-summary="manual">0</strong>
                </div>
                <div class="admin-summary-line u-mt-4">
                    <span data-i18n="exams.builderPage.summaryTotalScore">Tổng điểm</span>
                    <strong data-exam-question-summary="score">0</strong>
                </div>
                <div class="admin-summary-line u-mt-4">
                    <span data-i18n="exams.builderPage.summaryRandomRules">Quy tắc ngẫu nhiên</span>
                    <strong data-exam-question-summary="rules">0</strong>
                </div>
                <button class="app-button app-button-primary material-viewer-wide-action u-mt-4" type="button" data-exam-question-action="save" data-i18n="exams.builderPage.buttonSaveQuestions">Lưu câu hỏi</button>
            </div>
        </article>

        <article class="app-card u-mt-4">
            <div class="app-card-header">
                <h2 class="app-card-title" data-i18n="exams.builderPage.cardTitleRandomRuleBuilder">Trình tạo quy tắc ngẫu nhiên</h2>
                <p class="app-card-subtitle" data-i18n="exams.builderPage.cardSubtitleRandomRuleBuilder">Tạo quy tắc chọn câu hỏi ngẫu nhiên cho bài thi.</p>
            </div>
            <div class="app-card-body admin-user-form">
                <label class="auth-field"><span data-i18n="exams.builderPage.labelRandomRuleCategory">Danh mục</span>
                    <select class="app-select" data-random-rule-field="category">
                        <option value="" data-i18n="exams.builderPage.optionAnyCategory">Bất kỳ danh mục nào</option>
                    </select>
                </label>
                <label class="auth-field"><span data-i18n="exams.builderPage.labelRandomRuleDifficulty">Độ khó</span>
                    <select class="app-select" data-random-rule-field="difficulty">
                        <option value="" data-i18n="exams.builderPage.optionAnyDifficulty">Bất kỳ độ khó nào</option>
                        <option value="Easy" data-i18n="exams.builderPage.optionEasy">Dễ</option>
                        <option value="Medium" data-i18n="exams.builderPage.optionMedium">Trung bình</option>
                        <option value="Hard" data-i18n="exams.builderPage.optionHard">Khó</option>
                    </select>
                </label>
                <label class="auth-field"><span data-i18n="exams.builderPage.labelRandomRuleCount">Số lượng câu hỏi</span>
                    <input class="app-input" data-random-rule-field="count" type="number" min="1" step="1" value="1" />
                </label>
                <button class="app-button app-button-secondary" type="button" data-exam-question-action="add-random-rule" data-i18n="exams.builderPage.buttonAddRule">Thêm quy tắc</button>
                <div class="question-answer-list" id="examRandomRuleList"></div>
            </div>
        </article>
    </aside>
</section>

<section class="exam-builder-layout u-hidden" data-exam-builder-panel="assignment">
    <article class="app-card app-animate-slide-up">
        <div class="app-card-header">
            <div class="admin-card-header-row">
                <div>
                    <h2 class="app-card-title" data-i18n="exams.builderPage.cardTitleAssignment">Giao bài thi</h2>
                    <p class="app-card-subtitle" data-i18n="exams.builderPage.cardSubtitleAssignment">Giao bài thi này cho từng học viên hoặc nhóm học viên.</p>
                </div>
                <span class="app-badge app-badge-info" data-exam-assignment-count>-- đã giao</span>
            </div>
        </div>
        <div class="app-card-body">
            <div class="exam-assignment-grid">
                <div>
                    <div class="group-detail-add-row">
                        <label class="visually-hidden" for="examUserSelect" data-i18n="exams.builderPage.labelUserSelect">Giao cho người dùng</label>
                        <select class="app-select" id="examUserSelect" data-exam-assignment-select="user"></select>
                        <button class="app-button app-button-primary" type="button" data-exam-assignment-add="user" data-i18n="exams.builderPage.buttonAddUser">Thêm học viên</button>
                    </div>
                    <div class="group-detail-list u-mt-4" id="examAssignedUserList"></div>
                </div>

                <div>
                    <div class="group-detail-add-row">
                        <label class="visually-hidden" for="examGroupSelect" data-i18n="exams.builderPage.labelGroupSelect">Giao cho nhóm</label>
                        <select class="app-select" id="examGroupSelect" data-exam-assignment-select="group"></select>
                        <button class="app-button app-button-primary" type="button" data-exam-assignment-add="group" data-i18n="exams.builderPage.buttonAddGroup">Thêm nhóm</button>
                    </div>
                    <div class="group-detail-list u-mt-4" id="examAssignedGroupList"></div>
                </div>
            </div>
        </div>
    </article>

    <aside class="exam-builder-side">
        <article class="app-card">
            <div class="app-card-header">
                <h2 class="app-card-title" data-i18n="exams.builderPage.cardTitleAssignmentSummary">Tổng quan giao bài</h2>
                <p class="app-card-subtitle" data-i18n="exams.builderPage.cardSubtitleSaved">Lưu cùng với bản nháp bài thi.</p>
            </div>
            <div class="app-card-body">
                <div class="admin-summary-line">
                    <span data-i18n="exams.builderPage.summaryUsers">Học viên</span>
                    <strong data-exam-assignment-summary="users">0</strong>
                </div>
                <div class="admin-summary-line u-mt-4">
                    <span data-i18n="exams.builderPage.summaryGroups">Nhóm</span>
                    <strong data-exam-assignment-summary="groups">0</strong>
                </div>
                <button class="app-button app-button-primary material-viewer-wide-action u-mt-4" type="button" data-exam-assignment-action="save" data-i18n="exams.builderPage.buttonSaveAssignment">Lưu giao bài</button>
            </div>
        </article>
    </aside>
</section>

<section class="exam-builder-layout u-hidden" data-exam-builder-panel="settings">
    <article class="app-card app-animate-slide-up">
        <div class="app-card-header">
            <h2 class="app-card-title" data-i18n="exams.builderPage.cardTitleSettings">Cài đặt</h2>
            <p class="app-card-subtitle" data-i18n="exams.builderPage.cardSubtitleSettings">Quy định áp dụng khi học viên làm bài thi này.</p>
        </div>
        <form class="app-card-body admin-user-form" id="examSettingsForm" novalidate>
            <div class="admin-user-form-grid">
                <label class="auth-check exam-setting-check">
                    <input type="checkbox" name="shuffleQuestions" />
                    <span data-i18n="exams.builderPage.labelShuffleQuestions">Tráo thứ tự câu hỏi</span>
                </label>
                <label class="auth-check exam-setting-check">
                    <input type="checkbox" name="shuffleAnswers" />
                    <span data-i18n="exams.builderPage.labelShuffleAnswers">Tráo thứ tự đáp án</span>
                </label>
            </div>
            <div class="admin-user-form-grid">
                <label class="auth-check exam-setting-check">
                    <input type="checkbox" name="allowBackNavigation" />
                    <span data-i18n="exams.builderPage.labelAllowBackNav">Cho phép quay lại câu trước</span>
                </label>
                <label class="auth-check exam-setting-check">
                    <input type="checkbox" name="autoSubmit" checked />
                    <span data-i18n="exams.builderPage.labelAutoSubmit">Tự động nộp bài khi hết giờ</span>
                </label>
            </div>
            <div class="admin-user-form-grid">
                <label class="auth-field"><span data-i18n="exams.builderPage.labelAttemptLimit">Số lượt làm bài tối đa</span>
                    <input class="app-input" name="attemptLimit" type="number" min="1" step="1" value="1" />
                    <span class="auth-error" data-exam-settings-error="attemptLimit"></span>
                </label>
                <label class="auth-field"><span data-i18n="exams.builderPage.labelAutosaveSeconds">Thời gian tự động lưu (giây)</span>
                    <input class="app-input" name="autosaveSeconds" type="number" min="15" step="1" value="30" />
                    <span class="auth-error" data-exam-settings-error="autosaveSeconds"></span>
                </label>
            </div>
        </form>
    </article>

    <aside class="exam-builder-side">
        <article class="app-card">
            <div class="app-card-header">
                <h2 class="app-card-title" data-i18n="exams.builderPage.cardTitlePublish">Xuất bản</h2>
                <p class="app-card-subtitle" data-i18n="exams.builderPage.cardSubtitlePublish">Lưu cài đặt hoặc xuất bản bản nháp bài thi.</p>
            </div>
            <div class="app-card-body">
                <div class="admin-summary-line">
                    <span data-i18n="exams.builderPage.summaryStatus">Trạng thái</span>
                    <strong data-exam-settings-summary="status">Draft</strong>
                </div>
                <div class="admin-summary-line u-mt-4">
                    <span data-i18n="exams.builderPage.summaryQuestions">Câu hỏi</span>
                    <strong data-exam-settings-summary="questions">0</strong>
                </div>
                <div class="admin-summary-line u-mt-4">
                    <span data-i18n="exams.builderPage.summaryAssigned">Đã giao</span>
                    <strong data-exam-settings-summary="assigned">0</strong>
                </div>
                <button class="app-button app-button-secondary material-viewer-wide-action u-mt-4" type="button" data-exam-settings-action="save" data-i18n="exams.builderPage.buttonSaveSettings">Lưu cài đặt</button>
                <button class="app-button app-button-primary material-viewer-wide-action u-mt-4" type="button" data-exam-settings-action="publish" data-i18n="exams.builderPage.buttonPublishExam">Xuất bản bài thi</button>
            </div>
        </article>
    </aside>
</section>

@section Scripts {
    <script src="~/js/pages/exam-builder-general.js" asp-append-version="true"></script>
}
