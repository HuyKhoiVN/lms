@{
    ViewData["Title"] = "Chi tiết khóa học";
    var courseId = ViewData["CourseId"] ?? 0;
}

<div class="page-header" data-course-detail-id="@courseId">
    <div class="page-header-main">
        <nav class="page-breadcrumb" aria-label="Breadcrumb">
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" data-i18n="courses.detailPage.breadcrumbRoot">Quản trị</a>
            <span>/</span>
            <a asp-area="Admin" asp-controller="Courses" asp-action="Index" data-i18n="courses.detailPage.breadcrumbCourses">Khóa học</a>
            <span>/</span>
            <span data-i18n="courses.detailPage.breadcrumbCurrent">Chi tiết</span>
        </nav>
        <h1 class="page-title" data-course-detail-name data-i18n="courses.detailPage.heading">Chi tiết khóa học</h1>
        <p class="page-muted u-mb-0" data-course-detail-description data-i18n="courses.detailPage.loadingDescription">Đang tải chi tiết khóa học...</p>
    </div>
    <div class="page-header-actions">
        <a class="app-button app-button-secondary" asp-area="Admin" asp-controller="Courses" asp-action="Index" data-i18n="courses.detailPage.backToCourses">Quay lại khóa học</a>
        <button class="app-button app-button-primary" type="button" data-course-detail-action="publish" data-i18n="courses.detailPage.publish">Xuất bản</button>
    </div>
</div>

<section class="admin-screen-banner app-animate-slide-up">
    <div class="image-slot image-slot-banner image-slot-admin" data-image-label="Course detail banner 1200x220">
        <img src="~/images/course-ai-tech.jpg" alt="" aria-hidden="true" />
    </div>
</section>

<section class="page-grid page-grid-4 u-mb-4 app-animate-stagger" aria-label="Tổng quan chi tiết khóa học" data-i18n-aria="courses.detailPage.summary">
    <article class="app-card app-card-clickable">
        <div class="app-card-body app-metric">
            <div>
                <p class="app-metric-label" data-i18n="courses.detailPage.status">Trạng thái</p>
                <p class="app-metric-value" data-course-detail-metric="status">--</p>
            </div>
            <span class="app-metric-icon" aria-hidden="true"><i class="bi bi-toggle-on"></i></span>
        </div>
    </article>
    <article class="app-card app-card-clickable">
        <div class="app-card-body app-metric">
            <div>
                <p class="app-metric-label" data-i18n="courses.detailPage.materials">Tài liệu</p>
                <p class="app-metric-value" data-course-detail-metric="materials">--</p>
            </div>
            <span class="app-metric-icon" aria-hidden="true"><i class="bi bi-file-earmark-text"></i></span>
        </div>
    </article>
    <article class="app-card app-card-clickable">
        <div class="app-card-body app-metric">
            <div>
                <p class="app-metric-label" data-i18n="courses.detailPage.assigned">Đã giao</p>
                <p class="app-metric-value" data-course-detail-metric="assigned">--</p>
            </div>
            <span class="app-metric-icon" aria-hidden="true"><i class="bi bi-person-check"></i></span>
        </div>
    </article>
    <article class="app-card app-card-clickable">
        <div class="app-card-body app-metric">
            <div>
                <p class="app-metric-label" data-i18n="courses.detailPage.completion">Hoàn thành</p>
                <p class="app-metric-value" data-course-detail-metric="completion">--</p>
            </div>
            <span class="app-metric-icon" aria-hidden="true"><i class="bi bi-graph-up-arrow"></i></span>
        </div>
    </article>
</section>

<section class="course-detail-layout">
    <div class="course-detail-main">
        <article class="app-card">
            <div class="app-card-header">
                <div class="admin-card-header-row">
                    <div>
                        <h2 class="app-card-title" data-i18n="courses.detailPage.infoTitle">Thông tin khóa học</h2>
                        <p class="app-card-subtitle" data-i18n="courses.detailPage.infoSubtitle">Metadata khóa học và tiến độ học tập.</p>
                    </div>
                    <span class="app-badge app-badge-muted" data-course-detail-status>--</span>
                </div>
            </div>
            <div class="app-card-body">
                <div class="course-detail-hero">
                    <div class="image-slot image-slot-md image-slot-course admin-course-detail-image" data-image-label="Course image 320x180">
                        <img src="~/images/course-ai-tech.jpg" alt="" aria-hidden="true" />
                    </div>
                    <div class="course-thumb">
                        <span class="course-thumb-code" data-course-detail-code>--</span>
                        <span class="app-badge app-badge-info" data-course-detail-progress-badge>--</span>
                    </div>
                    <div>
                        <h3 class="app-card-title" data-course-detail-title data-i18n="courses.detailPage.loadingCourse">Đang tải khóa học...</h3>
                        <p class="page-muted" data-course-detail-copy data-i18n="courses.detailPage.loadingMockData">Đang tải dữ liệu mô phỏng...</p>
                        <div class="progress-track u-mt-4">
                            <div class="progress-fill" data-course-detail-progress></div>
                        </div>
                    </div>
                </div>
            </div>
        </article>

        <article class="app-card u-mt-4">
            <div class="app-card-header">
                <div class="admin-card-header-row">
                    <div>
                        <h2 class="app-card-title" data-i18n="courses.detailPage.materialsTitle">Tài liệu</h2>
                        <p class="app-card-subtitle" data-i18n="courses.detailPage.materialsSubtitle">Tài liệu học tập hiện được gắn với khóa học này.</p>
                    </div>
                    <span class="app-badge app-badge-info" data-course-detail-count="materials">-- materials</span>
                </div>
            </div>
            <div class="app-card-body">
                <div class="group-detail-list" id="courseMaterialList">
                    <div class="app-loading">
                        <span class="app-spinner" aria-hidden="true"></span>
                    <span data-i18n="courses.detailPage.loadingMaterials">Đang tải tài liệu...</span>
                    </div>
                </div>
            </div>
        </article>
    </div>

    <aside class="course-detail-side">
        <article class="app-card">
            <div class="app-card-header">
                <h2 class="app-card-title" data-i18n="courses.detailPage.assignedUsers">Người dùng được giao</h2>
                <p class="app-card-subtitle" data-i18n="courses.detailPage.assignedUsersSubtitle">Danh sách học viên được giao mô phỏng.</p>
            </div>
            <div class="app-card-body">
                <div class="group-detail-list" id="courseAssignedUsers"></div>
            </div>
        </article>

        <article class="app-card u-mt-4">
            <div class="app-card-header">
                <h2 class="app-card-title" data-i18n="courses.detailPage.assignedGroups">Nhóm được giao</h2>
                <p class="app-card-subtitle" data-i18n="courses.detailPage.assignedGroupsSubtitle">Danh sách nhóm được giao mô phỏng.</p>
            </div>
            <div class="app-card-body">
                <div class="group-detail-list" id="courseAssignedGroups"></div>
            </div>
        </article>
    </aside>
</section>

@section Scripts {
    <script src="~/js/pages/course-detail.js" asp-append-version="true"></script>
}
