@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var isHome = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase);
    var isCourses = string.Equals(currentController, "Courses", StringComparison.OrdinalIgnoreCase);
    var isMaterials = string.Equals(currentController, "LearningMaterials", StringComparison.OrdinalIgnoreCase);
    var isExams = string.Equals(currentController, "Exams", StringComparison.OrdinalIgnoreCase);
    var isResults = string.Equals(currentController, "Results", StringComparison.OrdinalIgnoreCase);
    var isCertificates = string.Equals(currentController, "Certificates", StringComparison.OrdinalIgnoreCase);
    var isNotifications = string.Equals(currentController, "Notifications", StringComparison.OrdinalIgnoreCase);
    var isSettings = string.Equals(currentController, "UserSettings", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - lms</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,300;1,400;1,500;1,600;1,700&family=Inter:ital,opsz,wght@0,14..32,300..800;1,14..32,300..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/animations.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/utilities.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lms.WebMvc.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell app-shell-user">
        <aside class="app-sidebar learning-sidebar" id="studentSidebar" aria-label="Điều hướng học viên" data-i18n-aria="layout.studentNavigation">
            <div class="app-brand">
                <a class="app-brand-link" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="app-brand-mark">L</span>
                    <span class="app-brand-text">lms</span>
                </a>
            </div>

            <nav class="app-nav">
                <div class="app-nav-section">
                    <a class="app-nav-link @(isHome ? "active" : null)" asp-area="" asp-controller="Home" asp-action="Index">
                        <span class="app-nav-icon" aria-hidden="true"><i class="bi bi-house-door"></i></span>
                        <span data-i18n="nav.overview">Tổng quan</span>
                    </a>
                    <a class="app-nav-link @(isCourses ? "active" : null)" asp-area="" asp-controller="Courses" asp-action="Index">
                        <span class="app-nav-icon" aria-hidden="true"><i class="bi bi-journal-bookmark"></i></span>
                        <span data-i18n="nav.courses">Khóa học</span>
                    </a>
                    <a class="app-nav-link @(isMaterials ? "active" : null)" asp-area="" asp-controller="LearningMaterials" asp-action="Index">
                        <span class="app-nav-icon" aria-hidden="true"><i class="bi bi-file-earmark-text"></i></span>
                        <span data-i18n="nav.materials">Tài liệu</span>
                    </a>
                    <a class="app-nav-link @(isExams ? "active" : null)" asp-area="" asp-controller="Exams" asp-action="Index">
                        <span class="app-nav-icon" aria-hidden="true"><i class="bi bi-clipboard-check"></i></span>
                        <span data-i18n="nav.exams">Bài thi</span>
                    </a>
                    <a class="app-nav-link @(isResults ? "active" : null)" asp-area="" asp-controller="Results" asp-action="Index">
                        <span class="app-nav-icon" aria-hidden="true"><i class="bi bi-clipboard2-data"></i></span>
                        <span data-i18n="nav.results">Kết quả</span>
                    </a>
                    <a class="app-nav-link @(isCertificates ? "active" : null)" asp-area="" asp-controller="Certificates" asp-action="Index">
                        <span class="app-nav-icon" aria-hidden="true"><i class="bi bi-award"></i></span>
                        <span data-i18n="nav.certificates">Chứng chỉ</span>
                    </a>
                    <a class="app-nav-link @(isNotifications ? "active" : null)" href="/Notifications">
                        <span class="app-nav-icon" aria-hidden="true"><i class="bi bi-bell"></i></span>
                        <span data-i18n="nav.notifications">Thông báo</span>
                    </a>
                    <a class="app-nav-link @(isSettings ? "active" : null)" href="/UserSettings">
                        <span class="app-nav-icon" aria-hidden="true"><i class="bi bi-gear"></i></span>
                        <span data-i18n="nav.settings">Cài đặt</span>
                    </a>
                </div>
            </nav>

            <div class="learning-sidebar-progress" aria-label="Tiến độ học tập">
                <span class="learning-sidebar-progress-icon" aria-hidden="true"><i class="bi bi-graph-up-arrow"></i></span>
                <p>Theo dõi học tập</p>
                <small>Xem kết quả, chứng chỉ và các bài thi cần tiếp tục.</small>
                <a asp-area="" asp-controller="Results" asp-action="Index">Xem chi tiết</a>
            </div>
        </aside>

        <button class="app-sidebar-backdrop" type="button" aria-label="Đóng menu điều hướng"></button>

        <div class="learning-shell-main">
        <header class="learning-header">
            <nav class="learning-nav" aria-label="Điều hướng học viên" data-i18n-aria="layout.studentNavigation">
                <button class="app-sidebar-toggle learning-sidebar-toggle" type="button" aria-label="Mở menu" aria-controls="studentSidebar" aria-expanded="false">
                    <i class="bi bi-list" aria-hidden="true"></i>
                </button>

                <a class="learning-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="learning-brand-mark">L</span>
                    <span>lms</span>
                </a>

                <div class="learning-menu">
                    <a class="learning-menu-link @(isHome ? "active" : null)" asp-area="" asp-controller="Home" asp-action="Index" data-i18n="nav.home">Trang chủ</a>
                    <a class="learning-menu-link @(isCourses ? "active" : null)" asp-area="" asp-controller="Courses" asp-action="Index" data-i18n="nav.courses">Khóa học</a>
                    <a class="learning-menu-link @(isMaterials ? "active" : null)" asp-area="" asp-controller="LearningMaterials" asp-action="Index" data-i18n="nav.materials">Tài liệu</a>
                    <a class="learning-menu-link @(isExams ? "active" : null)" asp-area="" asp-controller="Exams" asp-action="Index" data-i18n="nav.exams">Bài thi</a>
                    <a class="learning-menu-link @(isResults ? "active" : null)" asp-area="" asp-controller="Results" asp-action="Index" data-i18n="nav.results">Kết quả</a>
                    <a class="learning-menu-link @(isCertificates ? "active" : null)" asp-area="" asp-controller="Certificates" asp-action="Index" data-i18n="nav.certificates">Chứng chỉ</a>
                </div>

                <div class="learning-actions">
                    <form class="learning-search app-search" role="search">
                        <label class="visually-hidden" for="appSearch" data-i18n="common.search">Tìm kiếm</label>
                        <input id="appSearch" type="search" placeholder="Tìm bài học..." data-i18n-placeholder="layout.searchLessons" />
                    </form>
                    <label class="visually-hidden" for="languageSwitcher" data-i18n="common.language">Ngôn ngữ</label>
                    <select class="app-select app-language-switcher" id="languageSwitcher" data-i18n-language aria-label="Ngôn ngữ" data-i18n-aria="common.language">
                        <option value="vi">VI</option>
                        <option value="en">EN</option>
                    </select>
                    <a class="app-icon-button learning-notification-button" href="/Notifications" aria-label="Thông báo" data-i18n-aria="layout.notifications">
                        <i class="bi bi-bell" aria-hidden="true"></i>
                        <span aria-hidden="true"></span>
                    </a>
                    <div class="app-user-menu" data-dropdown>
                        <button class="app-user-trigger" type="button" data-dropdown-toggle aria-haspopup="true" aria-expanded="false">
                            <span class="app-avatar" aria-hidden="true">S</span>
                            <span class="app-user-copy">
                                <span class="app-user-name">Người dùng</span>
                                <span class="app-user-role" data-i18n="common.student">Học viên</span>
                            </span>
                            <i class="bi bi-chevron-down" aria-hidden="true"></i>
                        </button>
                        <div class="app-dropdown-menu" data-dropdown-menu>
                            <a class="app-dropdown-item" asp-area="" asp-controller="Auth" asp-action="ChangePassword" data-dropdown-close>
                                <i class="bi bi-key" aria-hidden="true"></i>
                                <span data-i18n="layout.changePassword">Mật khẩu</span>
                            </a>
                            <a class="app-dropdown-item" asp-area="Admin" asp-controller="Dashboard" asp-action="Index" data-dropdown-close>
                                <i class="bi bi-speedometer2" aria-hidden="true"></i>
                                <span data-i18n="common.admin">Quản trị</span>
                            </a>
                            <div class="app-dropdown-divider"></div>
                            <button class="app-dropdown-item" type="button" data-auth-action="logout" data-dropdown-close>
                                <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                                <span data-i18n="layout.logout">Đăng xuất</span>
                            </button>
                        </div>
                    </div>
                </div>
            </nav>
        </header>

        <main class="learning-main" role="main">
            @RenderBody()
        </main>

        @if (!ViewData.ContainsKey("HideStudentFooter"))
        {
            <footer class="learning-footer">
                <span data-i18n="layout.studentFooter">&copy; 2026 LMS Platform. Tất cả quyền được bảo lưu.</span>
                <div class="learning-footer-links">
                    <a href="#" data-i18n="layout.terms">Điều khoản</a>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" data-i18n="layout.privacy">Chính sách</a>
                    <a href="#" data-i18n="layout.support">Hỗ trợ</a>
                </div>
            </footer>
        }
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/core/config.js" asp-append-version="true"></script>
    <script src="~/js/core/runtime-config.js"></script>
    <script src="~/js/core/storage.js" asp-append-version="true"></script>
    <script src="~/js/core/i18n.js" asp-append-version="true"></script>
    <script src="~/js/core/backend-ready.js" asp-append-version="true"></script>
    <script src="~/js/core/auth.js" asp-append-version="true"></script>
    <script src="~/js/core/api-client.js" asp-append-version="true"></script>
    <script src="~/js/core/dropdown.js" asp-append-version="true"></script>
    <script src="~/js/core/toast.js" asp-append-version="true"></script>
    <script src="~/js/core/modal.js" asp-append-version="true"></script>
    <script src="~/js/core/ui.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
