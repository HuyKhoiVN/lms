<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - lms</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/animations.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/utilities.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lms.WebMvc.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell app-shell-user">
        <header class="learning-header">
            <nav class="learning-nav" aria-label="Điều hướng học viên" data-i18n-aria="layout.studentNavigation">
                <a class="learning-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="learning-brand-mark">L</span>
                    <span>lms</span>
                </a>

                <div class="learning-menu">
                    <a class="learning-menu-link active" asp-area="" asp-controller="Home" asp-action="Index" data-i18n="nav.home">Trang chủ</a>
                    <a class="learning-menu-link" asp-area="" asp-controller="Courses" asp-action="Index" data-i18n="nav.courses">Khóa học</a>
                    <a class="learning-menu-link" asp-area="" asp-controller="LearningMaterials" asp-action="Index" data-i18n="nav.materials">Tài liệu</a>
                    <a class="learning-menu-link" asp-area="" asp-controller="Exams" asp-action="Index" data-i18n="nav.exams">Bài thi</a>
                    <a class="learning-menu-link" asp-area="" asp-controller="Results" asp-action="Index" data-i18n="nav.results">Kết quả</a>
                    <a class="learning-menu-link" asp-area="" asp-controller="Certificates" asp-action="Index" data-i18n="nav.certificates">Chứng chỉ</a>
                </div>

                <div class="learning-actions">
                    <form class="learning-search app-search" role="search">
                        <label class="visually-hidden" for="appSearch" data-i18n="common.search">Tìm kiếm</label>
                        <input id="appSearch" type="search" placeholder="Tìm bài học..." data-i18n-placeholder="layout.searchLessons" />
                    </form>
                    <label class="visually-hidden" for="languageSwitcher" data-i18n="common.language">Ngôn ngữ</label>
                    <select class="app-select app-language-switcher" id="languageSwitcher" data-i18n-language aria-label="Ngôn ngữ" data-i18n-aria="common.language">
                        <option value="vi">VI</option>
                        <option value="en">EN</option>
                    </select>
                    <a class="app-button app-button-secondary" asp-area="" asp-controller="Auth" asp-action="ChangePassword" data-i18n="layout.changePassword">Mật khẩu</a>
                    <a class="app-button app-button-secondary" asp-area="Admin" asp-controller="Dashboard" asp-action="Index" data-i18n="common.admin">Quản trị</a>
                    <button class="app-button app-button-secondary" type="button" data-auth-action="logout" data-i18n="layout.logout">Đăng xuất</button>
                    <div class="app-user-menu" data-dropdown>
                        <button class="app-user-trigger" type="button" data-dropdown-toggle aria-haspopup="true" aria-expanded="false">
                            <span class="app-avatar" aria-hidden="true">S</span>
                            <span class="app-user-copy">
                                <span class="app-user-name" data-i18n="layout.currentStudent">Học viên Một</span>
                                <span class="app-user-role" data-i18n="common.student">Học viên</span>
                            </span>
                            <i class="bi bi-chevron-down" aria-hidden="true"></i>
                        </button>
                        <div class="app-dropdown-menu" data-dropdown-menu>
                            <a class="app-dropdown-item" asp-area="" asp-controller="Auth" asp-action="ChangePassword" data-dropdown-close>
                                <i class="bi bi-key" aria-hidden="true"></i>
                                <span data-i18n="layout.changePassword">Mật khẩu</span>
                            </a>
                            <a class="app-dropdown-item" asp-area="Admin" asp-controller="Dashboard" asp-action="Index" data-dropdown-close>
                                <i class="bi bi-speedometer2" aria-hidden="true"></i>
                                <span data-i18n="common.admin">Quản trị</span>
                            </a>
                            <div class="app-dropdown-divider"></div>
                            <button class="app-dropdown-item" type="button" data-auth-action="logout" data-dropdown-close>
                                <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                                <span data-i18n="layout.logout">Đăng xuất</span>
                            </button>
                        </div>
                    </div>
                </div>
            </nav>
        </header>

        <main class="learning-main" role="main">
            @RenderBody()
        </main>

        <footer class="learning-footer">
            <span data-i18n="layout.studentFooter">&copy; 2026 lms</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy" data-i18n="layout.privacy">Quyền riêng tư</a>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/core/config.js" asp-append-version="true"></script>
    <script src="~/js/core/storage.js" asp-append-version="true"></script>
    <script src="~/js/core/i18n.js" asp-append-version="true"></script>
    <script src="~/js/core/auth.js" asp-append-version="true"></script>
    <script src="~/js/core/api-client.js" asp-append-version="true"></script>
    <script src="~/js/core/dropdown.js" asp-append-version="true"></script>
    <script src="~/js/core/toast.js" asp-append-version="true"></script>
    <script src="~/js/core/modal.js" asp-append-version="true"></script>
    <script src="~/js/core/ui.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
