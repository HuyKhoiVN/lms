@{
    ViewData["Title"] = "Bảng điều khiển học viên";
    ViewData["HideStudentFooter"] = true;
}

<section class="student-dashboard-page" aria-label="Bảng điều khiển học viên">
    <section class="student-dashboard-command">
        <div class="student-dashboard-welcome">
            <p class="student-dashboard-kicker">Learning Dashboard</p>
            <h1>Chào <span data-current-user-name>Người dùng</span></h1>
            <p class="student-dashboard-intro">Tổng quan học tập và bài thi của bạn đang được đồng bộ từ hệ thống.</p>

            <ul class="student-dashboard-task-list" aria-label="Tổng quan nhanh">
                <li><strong data-student-metric="courses">--</strong> khóa học</li>
                <li><strong data-student-metric="pendingExams">--</strong> bài thi đang mở</li>
                <li><strong data-student-metric="certificates">--</strong> chứng chỉ</li>
            </ul>

            <div class="student-dashboard-actions">
                <a class="app-button app-button-primary" href="#studentCourseCards">Tiếp tục học</a>
                <a class="app-button app-button-secondary" asp-area="" asp-controller="Exams" asp-action="Index">Xem bài thi</a>
            </div>
        </div>

        <aside class="student-dashboard-attention" aria-label="Kết quả gần nhất">
            <div class="student-dashboard-attention-head">
                <span class="student-dashboard-alert-icon" aria-hidden="true"><i class="bi bi-graph-up-arrow"></i></span>
                <span>Kết quả gần nhất</span>
            </div>
            <h2 data-student-latest-exam>Đang tải...</h2>
            <p class="student-dashboard-due" data-student-latest-copy>Vui lòng chờ hệ thống đồng bộ dữ liệu.</p>

            <dl class="student-dashboard-exam-facts">
                <div>
                    <dt>Điểm số</dt>
                    <dd><span data-student-hero-score>--</span>/100</dd>
                </div>
                <div>
                    <dt>Bài thi cần làm</dt>
                    <dd data-student-exam-count>--</dd>
                </div>
            </dl>

            <div class="student-dashboard-progress-track" aria-hidden="true">
                <span data-student-latest-progress style="width: 0%"></span>
            </div>
        </aside>
    </section>

    <section class="student-dashboard-workspace">
        <div class="student-dashboard-main-column">
            <section class="student-dashboard-card student-dashboard-section" id="continue-learning">
                <div class="student-dashboard-section-head">
                    <div>
                        <p class="student-dashboard-kicker">Assigned Learning</p>
                        <h2>Khóa học của bạn</h2>
                    </div>
                    <span class="student-dashboard-count" data-student-metric="averageScore">--</span>
                </div>

                <div class="page-muted u-mb-4">Điểm trung bình từ các bài thi đã nộp.</div>
                <div class="page-grid page-grid-3" id="studentCourseCards">
                    <div class="app-loading">
                        <span class="app-spinner" aria-hidden="true"></span>
                        <span>Đang tải khóa học...</span>
                    </div>
                </div>
            </section>
        </div>

        <aside class="student-dashboard-side-column">
            <section class="student-dashboard-card student-dashboard-progress-summary">
                <div class="student-dashboard-section-head">
                    <div>
                        <p class="student-dashboard-kicker">Assessments</p>
                        <h2>Bài thi đang mở</h2>
                    </div>
                </div>
                <div id="studentPendingExams">
                    <div class="app-loading">
                        <span class="app-spinner" aria-hidden="true"></span>
                        <span>Đang tải bài thi...</span>
                    </div>
                </div>
            </section>

            <section class="student-dashboard-card student-dashboard-certificate">
                <div class="student-dashboard-section-head">
                    <h2>Chứng chỉ mới nhất</h2>
                    <i class="bi bi-award" aria-hidden="true"></i>
                </div>
                <div id="studentCertificateSummary">
                    <div class="app-loading">
                        <span class="app-spinner" aria-hidden="true"></span>
                        <span>Đang tải chứng chỉ...</span>
                    </div>
                </div>
            </section>
        </aside>
    </section>
</section>

@section Scripts {
    <script src="~/js/pages/student-dashboard.js" asp-append-version="true"></script>
}
