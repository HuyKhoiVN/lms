@{
    ViewData["Title"] = "Bắt đầu bài thi";
    var examId = ViewData["ExamId"] ?? 0;
}

<div class="page-header linear-start-exam-header start-exam-reveal" data-student-start-exam-id="@examId" data-start-exam-reveal>
    <div class="page-header-main">
        <nav class="page-breadcrumb" aria-label="Breadcrumb">
            <a asp-area="" asp-controller="Home" asp-action="Index" data-i18n="exams.startPage.breadcrumbHome">Trang chủ</a>
            <span>/</span>
            <a asp-area="" asp-controller="Exams" asp-action="Index" data-i18n="exams.startPage.breadcrumbExams">Bài thi</a>
            <span>/</span>
            <span data-i18n="exams.startPage.breadcrumbCurrent">Bắt đầu</span>
        </nav>
        <h1 class="page-title" data-start-exam-title data-i18n="exams.startPage.title">Bắt đầu bài thi</h1>
        <p class="page-muted u-mb-0" data-start-exam-subtitle data-i18n="exams.startPage.subtitle">Đang tải thông tin bài thi...</p>
    </div>
    <div class="page-header-actions">
        <a class="app-button app-button-secondary" asp-area="" asp-controller="Exams" asp-action="Index" data-i18n="exams.startPage.backToExams">Quay lại danh sách</a>
        <button class="app-button app-button-primary" type="button" data-start-exam-action="start" data-i18n="exams.startPage.buttonStart">Bắt đầu làm bài</button>
    </div>
</div>

<section class="start-exam-layout linear-start-exam-layout">
    <article class="app-card start-exam-card linear-start-exam-card start-exam-reveal" data-start-exam-reveal>
        <div class="app-card-header">
            <div class="admin-card-header-row">
                <div>
                    <h2 class="app-card-title" data-i18n="exams.startPage.cardTitleSummary">Tổng quan bài thi</h2>
                    <p class="app-card-subtitle" data-i18n="exams.startPage.cardSubtitleSummary">Kiểm tra các thông tin chính trước khi bắt đầu.</p>
                </div>
                <span class="app-badge app-badge-success" data-start-exam-status>--</span>
            </div>
        </div>
        <div class="app-card-body">
            <div class="start-exam-banner linear-start-exam-banner app-animate-fade start-exam-reveal" data-start-exam-reveal>
                <div class="image-slot image-slot-banner image-slot-exam" data-image-label="Exam start banner 1600x420">
                    <img src="~/images/placeholders/exam-placeholder.svg" alt="" aria-hidden="true" />
                </div>
            </div>
            <div class="start-exam-summary-grid">
                <div class="admin-summary-line start-exam-stat">
                    <span data-i18n="exams.startPage.summaryDuration">Thời lượng</span>
                    <strong data-start-exam-summary="duration">--</strong>
                </div>
                <div class="admin-summary-line start-exam-stat">
                    <span data-i18n="exams.startPage.summaryPassScore">Điểm đạt</span>
                    <strong data-start-exam-summary="passScore">--</strong>
                </div>
                <div class="admin-summary-line start-exam-stat">
                    <span data-i18n="exams.startPage.summaryQuestions">Số câu hỏi</span>
                    <strong data-start-exam-summary="questions">--</strong>
                </div>
                <div class="admin-summary-line start-exam-stat">
                    <span data-i18n="exams.startPage.summaryReview">Chính sách xem lại</span>
                    <strong data-start-exam-summary="review">--</strong>
                </div>
            </div>

            <div class="start-exam-note u-mt-4">
                <h3 data-i18n="exams.startPage.noticeTitle">Trước khi bắt đầu</h3>
                <p data-i18n="exams.startPage.noticeText">Không có đáp án đúng nào được hiển thị trước khi nộp bài. Câu trả lời của bạn sẽ được lưu cục bộ trong giai đoạn thử nghiệm UI này.</p>
            </div>
        </div>
    </article>

    <aside class="start-exam-side linear-start-exam-side">
        <article class="app-card linear-start-exam-rules start-exam-reveal" data-start-exam-reveal>
            <div class="app-card-header">
                <h2 class="app-card-title" data-i18n="exams.startPage.rulesTitle">Quy định</h2>
                <p class="app-card-subtitle" data-i18n="exams.startPage.rulesSubtitle">Tuân thủ các quy định sau trong quá trình làm bài.</p>
            </div>
            <div class="app-card-body">
                <div class="start-exam-rule-list" id="startExamRules">
                    <div class="app-loading">
                        <span class="app-spinner" aria-hidden="true"></span>
                        <span data-i18n="exams.startPage.loadingRules">Đang tải quy định...</span>
                    </div>
                </div>
            </div>
        </article>
    </aside>
</section>

@section Scripts {
    <script src="~/js/pages/student-exam-start.js" asp-append-version="true"></script>
}
