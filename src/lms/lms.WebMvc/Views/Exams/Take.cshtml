@{
    ViewData["Title"] = "Làm bài thi";
    var examId = ViewData["ExamId"] ?? 0;
}

<div class="exam-taking-shell" data-exam-taking-id="@examId">
    <header class="exam-taking-header">
        <div>
            <nav class="page-breadcrumb" aria-label="Breadcrumb">
                <a asp-area="" asp-controller="Home" asp-action="Index" data-i18n="exams.takePage.breadcrumbHome">Trang chủ</a>
                <span>/</span>
                <a asp-area="" asp-controller="Exams" asp-action="Index" data-i18n="exams.takePage.breadcrumbExams">Bài thi</a>
                <span>/</span>
                <span data-i18n="exams.takePage.breadcrumbCurrent">Đang làm bài</span>
            </nav>
            <h1 class="page-title" data-exam-taking-title data-i18n="exams.takePage.title">Đang làm bài</h1>
            <p class="page-muted u-mb-0" data-exam-taking-subtitle data-i18n="exams.takePage.subtitle">Đang tải bài thi...</p>
        </div>

        <div class="exam-timer-card" data-exam-timer-state="normal">
            <span data-i18n="exams.takePage.timerLabel">Thời gian còn lại</span>
            <strong data-exam-taking-timer>--:--</strong>
            <div class="exam-timer-progress" aria-hidden="true">
                <span data-exam-taking-timer-progress></span>
            </div>
        </div>
    </header>

    <section class="exam-taking-layout">
        <aside class="app-card exam-question-navigator">
            <div class="app-card-header">
                <h2 class="app-card-title" data-i18n="exams.takePage.cardTitleNavigator">Danh sách câu hỏi</h2>
                <p class="app-card-subtitle" data-exam-taking-progress>--</p>
            </div>
            <div class="app-card-body">
                <div class="exam-question-grid" id="examQuestionNavigator"></div>
            </div>
        </aside>

        <main class="app-card exam-question-panel app-animate-slide-up">
            <div class="app-card-header">
                <div class="admin-card-header-row">
                    <div>
                        <h2 class="app-card-title" data-exam-question-heading data-i18n="exams.takePage.cardTitleQuestion">Câu hỏi</h2>
                        <p class="app-card-subtitle" data-exam-question-meta>--</p>
                    </div>
                    <button class="app-button app-button-secondary" type="button" data-exam-taking-action="mark" data-i18n="exams.takePage.buttonMark">Đánh dấu</button>
                </div>
            </div>
            <div class="app-card-body">
                <p class="exam-question-content" data-exam-question-content data-i18n="exams.takePage.loadingQuestion">Đang tải câu hỏi...</p>
                <div class="exam-answer-list" id="examAnswerList"></div>
            </div>
            <div class="app-card-footer exam-taking-footer">
                <button class="app-button app-button-secondary" type="button" data-exam-taking-action="prev" data-i18n="exams.takePage.buttonPrev">Câu trước</button>
                <div class="exam-taking-footer-main">
                    <button class="app-button app-button-secondary" type="button" data-exam-taking-action="next" data-i18n="exams.takePage.buttonNext">Câu sau</button>
                    <button class="app-button app-button-primary" type="button" data-exam-taking-action="submit" data-i18n="exams.takePage.buttonSubmit">Nộp bài</button>
                </div>
            </div>
        </main>
    </section>
</div>

@section Scripts {
    <script src="~/js/pages/student-exam-taking.js" asp-append-version="true"></script>
}
