@{
    ViewData["Title"] = "Bài thi";
}

<div class="page-header">
    <div class="page-header-main">
        <nav class="page-breadcrumb" aria-label="Breadcrumb">
            <a asp-area="" asp-controller="Home" asp-action="Index" data-i18n="exams.studentListPage.breadcrumbHome">Trang chủ</a>
            <span>/</span>
            <span data-i18n="exams.studentListPage.breadcrumbExams">Bài thi</span>
        </nav>
        <h1 class="page-title" data-i18n="exams.studentListPage.title">Bài thi</h1>
        <p class="page-muted u-mb-0" data-i18n="exams.studentListPage.subtitle">Xem các bài thi được giao và bắt đầu khi bạn sẵn sàng.</p>
    </div>
</div>

<section class="student-exam-banner app-animate-slide-up">
    <div class="image-slot image-slot-banner image-slot-exam" data-image-label="Exam banner 1200x240">
        <img src="~/images/online-exam.jpg" alt="" aria-hidden="true" />
    </div>
</section>

<section class="app-card">
    <div class="app-card-header">
        <div class="admin-card-header-row">
            <div>
                <h2 class="app-card-title" data-i18n="exams.studentListPage.availableExams">Bài thi có sẵn</h2>
                <p class="app-card-subtitle" data-i18n="exams.studentListPage.onlyPublishedSubtitle">Chỉ bài thi đã xuất bản mới có thể bắt đầu làm.</p>
            </div>
            <span class="app-badge app-badge-info" data-student-exam-count data-i18n="exams.studentListPage.records">-- bài thi</span>
        </div>
    </div>
    <div class="app-card-body">
        <div class="student-exam-card-grid" id="studentExamGrid">
            <article class="app-card app-skeleton-card">
                <div class="app-card-body">
                    <span class="app-skeleton app-skeleton-image u-mb-4"></span>
                    <span class="app-skeleton u-mb-4"></span>
                    <span class="app-skeleton u-mb-4"></span>
                    <span class="app-skeleton"></span>
                </div>
            </article>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/pages/student-exam-list.js" asp-append-version="true"></script>
}
