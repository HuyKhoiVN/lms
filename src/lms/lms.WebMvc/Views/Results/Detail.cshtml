@{
    ViewData["Title"] = "Chi tiết kết quả";
    var resultId = ViewData["ResultId"] ?? "";
}

<section class="lms-workspace-page student-result-detail-page" data-result-detail-id="@resultId" aria-label="Chi tiết kết quả">
    <header class="lms-workspace-header student-result-detail-reveal" data-result-detail-reveal>
        <div class="lms-workspace-header-main">
            <nav class="page-breadcrumb" aria-label="Breadcrumb">
                <a asp-area="" asp-controller="Home" asp-action="Index" data-i18n="results.detailPage.breadcrumbHome">Trang chủ</a>
                <span>/</span>
                <a asp-area="" asp-controller="Results" asp-action="Index" data-i18n="results.detailPage.breadcrumbResults">Kết quả</a>
                <span>/</span>
                <span data-i18n="results.detailPage.breadcrumbCurrent">Chi tiết</span>
            </nav>
            <p class="lms-workspace-kicker">Result Review</p>
            <h1 data-result-detail-title data-i18n="results.detailPage.title">Chi tiết kết quả</h1>
            <p class="lms-workspace-description" data-result-detail-subtitle data-i18n="results.detailPage.subtitle">Đang tải kết quả...</p>
        </div>

        <a class="app-button app-button-secondary" asp-area="" asp-controller="Results" asp-action="Index" data-i18n="results.detailPage.backToResults">Quay lại danh sách</a>
    </header>

    <section class="student-result-detail-hero student-result-detail-reveal" data-result-detail-reveal>
        <div class="student-result-detail-score-ring" data-result-score-ring>
            <span data-result-detail-metric="scoreHero">--</span>
        </div>
        <div class="student-result-detail-hero-copy">
            <p class="lms-workspace-kicker">Score Summary</p>
            <h2 data-result-score-hero-title data-i18n="results.detailPage.cardTitleSummary">Thông tin lượt thi</h2>
            <p class="lms-workspace-description" data-result-score-hero-copy data-i18n="results.detailPage.cardSubtitleSummary">Thông tin nộp bài và chính sách xem lại.</p>
        </div>
        <div class="student-result-detail-hero-art image-slot image-slot-md image-slot-result" data-image-label="Result detail visual 320x180">
            <img src="~/images/placeholders/result-placeholder.svg" alt="" aria-hidden="true" />
        </div>
    </section>

    <section class="student-result-detail-metrics student-result-detail-reveal" data-result-detail-reveal>
        <article class="lms-workspace-card student-result-detail-metric-card">
            <span data-i18n="results.detailPage.metricScore">Điểm số</span>
            <strong data-result-detail-metric="score">--</strong>
        </article>
        <article class="lms-workspace-card student-result-detail-metric-card">
            <span data-i18n="results.detailPage.metricCorrect">Số câu đúng</span>
            <strong data-result-detail-metric="correct">--</strong>
        </article>
        <article class="lms-workspace-card student-result-detail-metric-card">
            <span data-i18n="results.detailPage.metricWrong">Số câu sai</span>
            <strong data-result-detail-metric="wrong">--</strong>
        </article>
        <article class="lms-workspace-card student-result-detail-metric-card">
            <span data-i18n="results.detailPage.metricDuration">Thời lượng</span>
            <strong data-result-detail-metric="duration">--</strong>
        </article>
    </section>

    <section class="student-result-detail-layout">
        <aside class="student-result-detail-side">
            <article class="lms-workspace-card student-result-detail-side-card student-result-detail-reveal" data-result-detail-reveal>
                <div class="lms-workspace-section-head">
                    <div>
                        <p class="lms-workspace-kicker">Attempt</p>
                        <h2 data-i18n="results.detailPage.cardTitleSummary">Thông tin lượt thi</h2>
                    </div>
                </div>

                <dl class="student-result-detail-summary">
                    <div>
                        <dt data-i18n="results.detailPage.summaryStatus">Trạng thái</dt>
                        <dd><span class="lms-status-info" data-result-detail-status>--</span></dd>
                    </div>
                    <div>
                        <dt data-i18n="results.detailPage.summaryPassScore">Điểm đạt</dt>
                        <dd data-result-detail-info="passScore">--</dd>
                    </div>
                    <div>
                        <dt data-i18n="results.detailPage.summaryReview">Chính sách xem lại</dt>
                        <dd data-result-detail-info="reviewPolicy">--</dd>
                    </div>
                    <div>
                        <dt data-i18n="results.detailPage.summarySubmitted">Đã nộp lúc</dt>
                        <dd data-result-detail-info="submittedAt">--</dd>
                    </div>
                    <div>
                        <dt data-i18n="results.detailPage.summaryStudent">Thành viên</dt>
                        <dd data-result-detail-info="studentName">--</dd>
                    </div>
                </dl>
            </article>
        </aside>

        <main class="lms-workspace-card student-result-detail-main student-result-detail-reveal" data-result-detail-reveal>
            <div class="lms-workspace-section-head">
                <div>
                    <p class="lms-workspace-kicker">Review</p>
                    <h2 data-i18n="results.detailPage.cardTitleReview">Xem lại bài làm</h2>
                    <p class="lms-workspace-description" data-result-review-copy data-i18n="results.detailPage.cardSubtitleReview">Đang tải chính sách xem lại...</p>
                </div>
                <span class="lms-workspace-count" data-result-review-count data-i18n="results.detailPage.reviewQuestionsCount">-- câu hỏi</span>
            </div>

            <div id="resultReviewContent">
                <div class="app-loading">
                    <span class="app-spinner" aria-hidden="true"></span>
                    <span data-i18n="results.detailPage.loadingDetail">Đang tải chi tiết kết quả...</span>
                </div>
            </div>
        </main>
    </section>
</section>

@section Scripts {
    <script src="~/js/pages/student-result-detail.js" asp-append-version="true"></script>
}
