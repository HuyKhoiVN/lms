@{
    ViewData["Title"] = "Kết quả học tập";
}

<div class="page-header linear-result-list-header result-list-reveal" data-result-list-reveal>
    <div class="page-header-main">
        <nav class="page-breadcrumb" aria-label="Breadcrumb">
            <a asp-area="" asp-controller="Home" asp-action="Index" data-i18n="results.listPage.breadcrumbHome">Trang chủ</a>
            <span>/</span>
            <span data-i18n="results.listPage.breadcrumbResults">Kết quả</span>
        </nav>
        <h1 class="page-title" data-i18n="results.listPage.title">Kết quả học tập</h1>
        <p class="page-muted u-mb-0" data-i18n="results.listPage.subtitle">Xem kết quả các bài thi đã nộp và trạng thái đạt/không đạt của bạn.</p>
    </div>
</div>

<section class="student-result-banner linear-result-banner app-animate-slide-up result-list-reveal" data-result-list-reveal>
    <div class="image-slot image-slot-banner image-slot-result" data-image-label="Results banner 1600x420">
        <img src="~/images/placeholders/result-placeholder.svg" alt="" aria-hidden="true" />
    </div>
</section>

<section class="page-grid page-grid-4 u-mb-4 app-animate-stagger linear-result-metrics" aria-label="Result summary">
    <article class="app-card app-card-clickable linear-result-metric result-list-reveal" data-result-list-reveal>
        <div class="app-card-body app-metric">
            <div>
                <p class="app-metric-label" data-i18n="results.listPage.metricTotal">Tổng số lượt làm</p>
                <p class="app-metric-value" data-result-metric="total">--</p>
            </div>
            <span class="app-metric-icon" aria-hidden="true"><i class="bi bi-clipboard2-data"></i></span>
        </div>
    </article>
    <article class="app-card app-card-clickable linear-result-metric result-list-reveal" data-result-list-reveal>
        <div class="app-card-body app-metric">
            <div>
                <p class="app-metric-label" data-i18n="results.listPage.metricPassed">Đạt</p>
                <p class="app-metric-value" data-result-metric="passed">--</p>
            </div>
            <span class="app-metric-icon" aria-hidden="true"><i class="bi bi-check2-circle"></i></span>
        </div>
    </article>
    <article class="app-card app-card-clickable linear-result-metric result-list-reveal" data-result-list-reveal>
        <div class="app-card-body app-metric">
            <div>
                <p class="app-metric-label" data-i18n="results.listPage.metricAverage">Điểm trung bình</p>
                <p class="app-metric-value" data-result-metric="average">--</p>
            </div>
            <span class="app-metric-icon" aria-hidden="true"><i class="bi bi-graph-up-arrow"></i></span>
        </div>
    </article>
    <article class="app-card app-card-clickable linear-result-metric result-list-reveal" data-result-list-reveal>
        <div class="app-card-body app-metric">
            <div>
                <p class="app-metric-label" data-i18n="results.listPage.metricLatest">Điểm gần nhất</p>
                <p class="app-metric-value" data-result-metric="latest">--</p>
            </div>
            <span class="app-metric-icon" aria-hidden="true"><i class="bi bi-stars"></i></span>
        </div>
    </article>
</section>

<section class="app-card linear-result-history-card result-list-reveal" data-result-list-reveal>
    <div class="app-card-header">
        <div class="admin-card-header-row">
            <div>
                <h2 class="app-card-title" data-i18n="results.listPage.cardTitleHistory">Lịch sử kết quả</h2>
                <p class="app-card-subtitle" data-i18n="results.listPage.cardSubtitleHistory">Bao gồm kết quả mô phỏng JSON và kết quả thi thực tế được nộp cục bộ.</p>
            </div>
            <span class="app-badge app-badge-info" data-result-count data-i18n="results.listPage.records">-- bản ghi</span>
        </div>
    </div>

    <div class="app-card-body">
        <div class="app-filter-bar admin-user-filter linear-result-filter-bar">
            <label class="visually-hidden" for="resultSearch" data-i18n="results.listPage.searchLabel">Tìm kiếm kết quả</label>
            <input class="app-input" id="resultSearch" type="search" placeholder="Tìm tên bài thi..." data-result-filter="search" data-i18n-placeholder="results.listPage.searchPlaceholder" />

            <label class="visually-hidden" for="resultStatusFilter" data-i18n="results.listPage.statusLabel">Trạng thái</label>
            <select class="app-select" id="resultStatusFilter" data-result-filter="status">
                <option value="" data-i18n="results.listPage.optionAllStatus">Tất cả trạng thái</option>
                <option value="passed" data-i18n="results.listPage.optionPassed">Đạt</option>
                <option value="failed" data-i18n="results.listPage.optionFailed">Không đạt</option>
            </select>

            <button class="app-button app-button-secondary" type="button" data-result-action="clear-filters" data-i18n="results.listPage.clearFilters">Xóa bộ lọc</button>
        </div>

        <div class="app-table-wrapper linear-result-table-wrapper u-mt-4">
            <table class="app-table table student-result-table">
                <thead>
                    <tr>
                        <th scope="col" data-i18n="results.listPage.tableHeaderExam">Bài thi</th>
                        <th scope="col" data-i18n="results.listPage.tableHeaderScore">Điểm số</th>
                        <th scope="col" data-i18n="results.listPage.tableHeaderStatus">Trạng thái</th>
                        <th scope="col" data-i18n="results.listPage.tableHeaderDuration">Thời gian làm bài</th>
                        <th scope="col" data-i18n="results.listPage.tableHeaderSubmitted">Thời gian nộp</th>
                        <th scope="col" class="u-text-right" data-i18n="results.listPage.tableHeaderActions">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="studentResultRows">
                    <tr>
                        <td colspan="6">
                            <div class="app-loading">
                                <span class="app-spinner" aria-hidden="true"></span>
                                <span data-i18n="results.listPage.loadingResults">Đang tải kết quả...</span>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/pages/student-result-list.js" asp-append-version="true"></script>
}
