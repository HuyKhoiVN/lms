@{
    ViewData["Title"] = "Tài liệu học tập";
}

<section class="lms-workspace-page student-material-assigned-page" aria-label="Tài liệu học tập được giao">
    <header class="lms-workspace-header student-material-reveal" data-material-reveal>
        <div class="lms-workspace-header-main">
            <nav class="page-breadcrumb" aria-label="Breadcrumb">
                <a asp-area="" asp-controller="Home" asp-action="Index" data-i18n="materials.studentListPage.breadcrumbHome">Trang chủ</a>
                <span>/</span>
                <span data-i18n="materials.studentListPage.breadcrumbMaterials">Tài liệu</span>
            </nav>
            <p class="lms-workspace-kicker">Assigned Learning Content</p>
            <h1 data-i18n="materials.studentListPage.title">Tài liệu học tập</h1>
            <p class="lms-workspace-description" data-i18n="materials.studentListPage.subtitle">
                Danh sách học liệu được giao theo khóa học, trạng thái và tiến độ của bạn.
            </p>
        </div>

        <a class="app-button app-button-primary" asp-area="" asp-controller="LearningMaterials" asp-action="Viewer" asp-route-id="1">Tiếp tục học</a>
    </header>

    <section class="lms-workspace-card student-material-reveal" data-material-reveal>
        <div class="lms-workspace-section-head">
            <div>
                <p class="lms-workspace-kicker">Materials</p>
                <h2 data-i18n="materials.studentListPage.assignedMaterials">Tài liệu được giao</h2>
            </div>
            <span class="lms-workspace-count" data-student-material-count data-i18n="materials.studentListPage.records">-- tài liệu</span>
        </div>

        <div class="lms-task-filter-bar" role="search" aria-label="Bộ lọc tài liệu học tập">
            <label class="visually-hidden" for="studentMaterialSearch" data-i18n="materials.studentListPage.searchLabel">Tìm kiếm tài liệu</label>
            <input class="app-input" id="studentMaterialSearch" type="search" placeholder="Tìm kiếm tài liệu..." data-student-material-filter="search" data-i18n-placeholder="materials.studentListPage.searchPlaceholder" />

            <label class="visually-hidden" for="studentMaterialCourseFilter" data-i18n="materials.studentListPage.courseLabel">Khóa học</label>
            <select class="app-select" id="studentMaterialCourseFilter" data-student-material-filter="course">
                <option value="" data-i18n="materials.studentListPage.allCourses">Tất cả khóa học</option>
            </select>

            <label class="visually-hidden" for="studentMaterialTypeFilter" data-i18n="materials.studentListPage.typeLabel">Loại tài liệu</label>
            <select class="app-select" id="studentMaterialTypeFilter" data-student-material-filter="type">
                <option value="" data-i18n="materials.studentListPage.allTypes">Tất cả các loại</option>
                <option value="Text" data-i18n="materials.studentListPage.typeText">Văn bản</option>
                <option value="Pdf" data-i18n="materials.studentListPage.typePdf">PDF</option>
                <option value="File" data-i18n="materials.studentListPage.typeFile">Tệp tin</option>
                <option value="Link" data-i18n="materials.studentListPage.typeLink">Liên kết</option>
            </select>

            <button class="app-button app-button-secondary" type="button" data-student-material-action="clear-filters" data-i18n="materials.studentListPage.clearFilters">Xóa bộ lọc</button>
        </div>

        <div class="student-material-grid" id="studentMaterialGrid">
            <article class="student-material-card student-material-reveal" data-material-reveal>
                <div class="student-material-type-row">
                    <span class="app-skeleton" style="width: 42px; height: 42px; border-radius: 8px;"></span>
                    <span class="app-skeleton" style="width: 80px; height: 26px; border-radius: 999px;"></span>
                </div>
                <span class="app-skeleton u-mt-4" style="height: 24px;"></span>
                <span class="app-skeleton u-mt-4"></span>
                <span class="app-skeleton u-mt-4"></span>
            </article>
        </div>
    </section>
</section>

@section Scripts {
    <script src="~/js/pages/student-material-list.js" asp-append-version="true"></script>
}
