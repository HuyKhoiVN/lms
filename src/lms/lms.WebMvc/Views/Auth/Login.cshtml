@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_AuthLayout";
}

<section class="auth-page">
    <div class="auth-visual" aria-label="Nền tảng học tập và thi trực tuyến" data-i18n-aria="auth.loginPage.visualLabel">
        <a class="learning-brand" asp-area="" asp-controller="Home" asp-action="Index">
            <span class="learning-brand-mark">L</span>
            <span>lms</span>
        </a>

        <div class="auth-hero-copy">
            <span class="learning-eyebrow" data-i18n="auth.loginPage.eyebrow">Học tập + Thi cử</span>
            <h1 class="auth-title" data-i18n="auth.loginPage.heroTitle">Phát triển kỹ năng và kiểm chứng năng lực trong một không gian.</h1>
            <p class="auth-copy" data-i18n="auth.loginPage.heroCopy">Tiếp tục khóa học được giao, làm bài thi an toàn, xem lại điểm số và tải chứng chỉ.</p>
        </div>

        <div class="image-slot image-slot-hero auth-visual-image" data-image-label="Auth learning visual 640x360">
            <img src="~/images/study-collaboration.jpg" alt="" aria-hidden="true" />
        </div>

        <div class="auth-preview-card">
            <div class="app-metric">
                <div>
                    <p class="app-metric-label" data-i18n="auth.loginPage.latestScore">Điểm gần nhất</p>
                    <p class="app-metric-value">86</p>
                    <span class="app-badge app-badge-success" data-i18n="auth.loginPage.passed">Đạt</span>
                </div>
                <span class="app-metric-icon" aria-hidden="true"><i class="bi bi-graph-up-arrow"></i></span>
            </div>
            <div class="progress-track u-mt-4">
                <div class="progress-fill progress-fill-86"></div>
            </div>
        </div>
    </div>

    <div class="auth-panel-wrap">
        <form class="auth-panel" id="loginForm" novalidate>
            <div class="auth-panel-header">
                <span class="learning-eyebrow" data-i18n="auth.loginPage.welcome">Chào mừng trở lại</span>
                <h2 class="section-title" data-i18n="auth.loginPage.signInTitle">Đăng nhập vào lms</h2>
                <p class="page-muted u-mb-0" data-i18n="auth.loginPage.mockCopy">Sử dụng tài khoản mô phỏng trong giai đoạn chưa tích hợp API.</p>
            </div>

            <div class="auth-demo-grid" aria-label="Tài khoản mô phỏng" data-i18n-aria="auth.loginPage.mockAccounts">
                <button class="auth-demo-account" type="button" data-login-role="Student">
                    <span class="app-avatar" aria-hidden="true"><i class="bi bi-person"></i></span>
                    <span>
                        <strong data-i18n="auth.loginPage.studentAccount">Học viên</strong>
                        <small>student01 / 123456</small>
                    </span>
                </button>
                <button class="auth-demo-account" type="button" data-login-role="Admin">
                    <span class="app-avatar" aria-hidden="true"><i class="bi bi-shield-lock"></i></span>
                    <span>
                        <strong data-i18n="auth.loginPage.adminAccount">Quản trị</strong>
                        <small>admin / 123456</small>
                    </span>
                </button>
            </div>

            <div class="u-flex-column u-gap-3">
                <label class="auth-field">
                    <span data-i18n="auth.loginPage.username">Tên đăng nhập</span>
                    <input class="app-input" id="username" name="username" type="text" autocomplete="username" required />
                    <small class="auth-error" data-valmsg-for="username"></small>
                </label>

                <label class="auth-field">
                    <span data-i18n="auth.password">Mật khẩu</span>
                    <input class="app-input" id="password" name="password" type="password" autocomplete="current-password" required />
                    <small class="auth-error" data-valmsg-for="password"></small>
                </label>
            </div>

            <div class="auth-options">
                <label class="auth-check">
                    <input type="checkbox" checked />
                    <span data-i18n="auth.loginPage.rememberMe">Ghi nhớ đăng nhập</span>
                </label>
                <a asp-area="" asp-controller="Home" asp-action="Index" data-i18n="auth.loginPage.needHelp">Cần trợ giúp?</a>
            </div>

            <button class="app-button app-button-primary auth-submit" type="submit" data-i18n="auth.loginPage.signInButton">Đăng nhập</button>
        </form>
    </div>
</section>

@section Scripts {
    <script src="~/js/pages/login.js" asp-append-version="true"></script>
}
