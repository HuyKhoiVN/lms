@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "_AuthLayout";
}

<section class="auth-page auth-page-security">
    <div class="auth-visual auth-visual-security app-animate-slide-right">
        <div class="auth-visual-top">
            <a class="learning-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="learning-brand-mark">L</span>
                <span>lms</span>
            </a>

            <div class="auth-hero-copy">
                <nav class="page-breadcrumb auth-breadcrumb" aria-label="Breadcrumb">
                    <a asp-area="" asp-controller="Home" asp-action="Index" data-i18n="auth.changePasswordPage.account">Tài khoản</a>
                    <span aria-hidden="true">/</span>
                    <span data-i18n="auth.changePasswordPage.breadcrumb">Đổi mật khẩu</span>
                </nav>
                <span class="learning-eyebrow" data-i18n="auth.changePasswordPage.account">Tài khoản</span>
                <h1 class="auth-title auth-title-compact" data-i18n="auth.changePasswordPage.heading">Đổi mật khẩu</h1>
                <p class="auth-copy auth-copy-compact" data-i18n="auth.changePasswordPage.subtitle">Cập nhật mật khẩu mô phỏng trước khi tích hợp API.</p>
            </div>
        </div>

        <div class="auth-visual-stage">
            <div class="image-slot image-slot-hero auth-visual-image auth-security-image" data-image-label="Password security visual 640x360">
                <img src="~/images/placeholders/auth-visual-placeholder.svg" alt="" aria-hidden="true" />
            </div>

            <div class="auth-security-overview app-animate-stagger">
                <article class="auth-security-panel-card">
                    <span class="app-badge app-badge-info" data-i18n="auth.changePasswordPage.tip">Gợi ý</span>
                    <h2 class="auth-security-panel-title" data-i18n="auth.changePasswordPage.tipTitle">Dùng mật khẩu thử nghiệm dễ nhớ</h2>
                    <p class="auth-security-panel-copy" data-i18n="auth.changePasswordPage.tipMessage">Tối thiểu 6 ký tự và phần xác nhận phải khớp.</p>
                </article>

                <div class="auth-security-chip-row">
                    <span class="auth-security-chip">123456</span>
                    <span class="auth-security-chip">6+</span>
                    <span class="auth-security-chip is-quiet">=</span>
                </div>
            </div>
        </div>
    </div>

    <div class="auth-panel-wrap auth-panel-wrap-wide">
        <form class="auth-panel auth-panel-security app-animate-scale-in" id="changePasswordForm" novalidate>
            <div class="auth-panel-header">
                <span class="learning-eyebrow" data-i18n="auth.changePasswordPage.rulesTitle">Quy tắc mật khẩu</span>
                <h2 class="section-title" data-i18n="auth.changePasswordPage.detailsTitle">Thông tin mật khẩu</h2>
                <p class="page-muted u-mb-0"><span data-i18n="auth.changePasswordPage.detailsSubtitle">Ở chế độ mô phỏng, mật khẩu hiện tại là</span> <strong>123456</strong>.</p>
            </div>

            <div class="auth-panel-note">
                <span data-i18n="auth.changePasswordPage.rulesSubtitle">Hiện kiểm tra ở client, sau này sẽ kiểm tra bằng API.</span>
            </div>

            <div class="u-flex-column u-gap-3">
                <label class="auth-field">
                    <span data-i18n="auth.changePasswordPage.currentPassword">Mật khẩu hiện tại</span>
                    <input class="app-input" id="oldPassword" name="oldPassword" type="password" autocomplete="current-password" required />
                    <small class="auth-error" data-valmsg-for="oldPassword"></small>
                </label>

                <label class="auth-field">
                    <span data-i18n="auth.changePasswordPage.newPassword">Mật khẩu mới</span>
                    <input class="app-input" id="newPassword" name="newPassword" type="password" autocomplete="new-password" required />
                    <small class="auth-error" data-valmsg-for="newPassword"></small>
                </label>

                <label class="auth-field">
                    <span data-i18n="auth.changePasswordPage.confirmPassword">Xác nhận mật khẩu mới</span>
                    <input class="app-input" id="confirmPassword" name="confirmPassword" type="password" autocomplete="new-password" required />
                    <small class="auth-error" data-valmsg-for="confirmPassword"></small>
                </label>
            </div>

            <div class="auth-security-actions">
                <a class="app-button app-button-secondary" asp-area="" asp-controller="Home" asp-action="Index" data-i18n="common.cancel">Hủy</a>
                <button class="app-button app-button-primary" type="submit" data-i18n="auth.changePasswordPage.updateButton">Cập nhật mật khẩu</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <script src="~/js/pages/change-password.js" asp-append-version="true"></script>
}
