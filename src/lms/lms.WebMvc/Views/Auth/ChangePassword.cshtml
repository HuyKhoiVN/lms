@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="page-header">
    <div class="page-header-main">
        <nav class="page-breadcrumb" aria-label="Breadcrumb">
            <a asp-area="" asp-controller="Home" asp-action="Index" data-i18n="auth.changePasswordPage.account">Tài khoản</a>
            <span aria-hidden="true">/</span>
            <span data-i18n="auth.changePasswordPage.breadcrumb">Đổi mật khẩu</span>
        </nav>
        <h1 class="page-title" data-i18n="auth.changePasswordPage.heading">Đổi mật khẩu</h1>
        <p class="page-muted u-mb-0" data-i18n="auth.changePasswordPage.subtitle">Cập nhật mật khẩu mô phỏng trước khi tích hợp API.</p>
    </div>
</div>

<section class="page-grid page-grid-2">
    <form class="app-card account-form app-animate-slide-up" id="changePasswordForm" novalidate>
        <div class="app-card-header">
            <h2 class="app-card-title" data-i18n="auth.changePasswordPage.detailsTitle">Thông tin mật khẩu</h2>
            <p class="app-card-subtitle"><span data-i18n="auth.changePasswordPage.detailsSubtitle">Ở chế độ mô phỏng, mật khẩu hiện tại là</span> <strong>123456</strong>.</p>
        </div>
        <div class="app-card-body u-flex-column u-gap-3">
            <label class="auth-field">
                <span data-i18n="auth.changePasswordPage.currentPassword">Mật khẩu hiện tại</span>
                <input class="app-input" id="oldPassword" name="oldPassword" type="password" autocomplete="current-password" required />
                <small class="auth-error" data-valmsg-for="oldPassword"></small>
            </label>

            <label class="auth-field">
                <span data-i18n="auth.changePasswordPage.newPassword">Mật khẩu mới</span>
                <input class="app-input" id="newPassword" name="newPassword" type="password" autocomplete="new-password" required />
                <small class="auth-error" data-valmsg-for="newPassword"></small>
            </label>

            <label class="auth-field">
                <span data-i18n="auth.changePasswordPage.confirmPassword">Xác nhận mật khẩu mới</span>
                <input class="app-input" id="confirmPassword" name="confirmPassword" type="password" autocomplete="new-password" required />
                <small class="auth-error" data-valmsg-for="confirmPassword"></small>
            </label>
        </div>
        <div class="app-card-footer account-form-actions">
            <a class="app-button app-button-secondary" asp-area="" asp-controller="Home" asp-action="Index" data-i18n="common.cancel">Hủy</a>
            <button class="app-button app-button-primary" type="submit" data-i18n="auth.changePasswordPage.updateButton">Cập nhật mật khẩu</button>
        </div>
    </form>

    <aside class="app-card change-password-rules app-animate-slide-up">
        <div class="image-slot image-slot-md image-slot-auth change-password-visual" data-image-label="Password security visual 320x180">
            <img src="~/images/placeholders/auth-visual-placeholder.svg" alt="" aria-hidden="true" />
        </div>
        <div class="app-card-header">
            <h2 class="app-card-title" data-i18n="auth.changePasswordPage.rulesTitle">Quy tắc mật khẩu</h2>
            <p class="app-card-subtitle" data-i18n="auth.changePasswordPage.rulesSubtitle">Hiện kiểm tra ở client, sau này sẽ kiểm tra bằng API.</p>
        </div>
        <div class="app-card-body">
            <div class="app-toast app-toast-info" role="status">
                <span class="app-badge app-badge-info" data-i18n="auth.changePasswordPage.tip">Gợi ý</span>
                <div>
                    <p class="app-toast-title" data-i18n="auth.changePasswordPage.tipTitle">Dùng mật khẩu thử nghiệm dễ nhớ</p>
                    <p class="app-toast-message" data-i18n="auth.changePasswordPage.tipMessage">Tối thiểu 6 ký tự và phần xác nhận phải khớp.</p>
                </div>
            </div>
        </div>
    </aside>
</section>

@section Scripts {
    <script src="~/js/pages/change-password.js" asp-append-version="true"></script>
}
