@{
    ViewData["Title"] = "Chứng chỉ";
}

<section class="lms-workspace-page student-certificate-page" aria-label="Chứng chỉ">
    <header class="lms-workspace-header student-certificate-reveal" data-certificate-reveal>
        <div class="lms-workspace-header-main">
            <nav class="page-breadcrumb" aria-label="Breadcrumb">
                <a asp-area="" asp-controller="Home" asp-action="Index" data-i18n="certificates.listPage.breadcrumbHome">Trang chủ</a>
                <span>/</span>
                <span data-i18n="certificates.listPage.breadcrumbCertificates">Chứng chỉ</span>
            </nav>
            <p class="lms-workspace-kicker">Issued Certificates</p>
            <h1 data-i18n="certificates.listPage.title">Chứng chỉ</h1>
            <p class="lms-workspace-description" data-i18n="certificates.listPage.subtitle">
                Xem các chứng chỉ đã đạt được, preview nhanh và tải file chứng chỉ trực tiếp từ backend.
            </p>
        </div>

        <div class="student-dashboard-actions">
            <a class="app-button app-button-secondary" asp-area="" asp-controller="Results" asp-action="Index">Xem kết quả</a>
            <a class="app-button app-button-primary" asp-area="" asp-controller="Exams" asp-action="Index">Xem bài thi</a>
        </div>
    </header>

    <section class="student-certificate-metrics student-certificate-reveal" data-certificate-reveal>
        <article class="lms-workspace-card student-certificate-metric-card">
            <span data-i18n="certificates.listPage.metricTotal">Tổng chứng chỉ</span>
            <strong data-certificate-metric="total">--</strong>
        </article>
        <article class="lms-workspace-card student-certificate-metric-card">
            <span data-i18n="certificates.listPage.metricLatest">Cấp gần nhất</span>
            <strong data-certificate-metric="latest">--</strong>
        </article>
        <article class="lms-workspace-card student-certificate-metric-card">
            <span data-i18n="certificates.listPage.metricAvailable">Có thể tải</span>
            <strong data-certificate-metric="available">--</strong>
        </article>
    </section>

    <section class="student-certificate-layout">
        <main class="lms-workspace-card student-certificate-main student-certificate-reveal" data-certificate-reveal>
            <div class="lms-workspace-section-head">
                <div>
                    <p class="lms-workspace-kicker">Gallery</p>
                    <h2 data-i18n="certificates.listPage.cardTitleHistory">Danh sách chứng chỉ</h2>
                    <p class="lms-workspace-description" data-i18n="certificates.listPage.cardSubtitleHistory">
                        Chứng chỉ được tải từ dữ liệu thực và hỗ trợ tải file ngay trên màn hình này.
                    </p>
                </div>
                <span class="lms-workspace-count" data-certificate-count data-i18n="certificates.listPage.records">-- bản ghi</span>
            </div>

            <div class="lms-task-filter-bar" role="search" aria-label="Bộ lọc chứng chỉ">
                <label class="visually-hidden" for="certificateSearch" data-i18n="certificates.listPage.searchLabel">Tìm kiếm chứng chỉ</label>
                <input class="app-input" id="certificateSearch" type="search" placeholder="Tìm tên bài thi hoặc mã chứng chỉ..." data-certificate-filter="search" data-i18n-placeholder="certificates.listPage.searchPlaceholder" />

                <div></div>
                <div></div>

                <button class="app-button app-button-secondary" type="button" data-certificate-action="clear-filters" data-i18n="certificates.listPage.clearFilters">Xóa bộ lọc</button>
            </div>

            <div class="student-certificate-grid" id="certificateGrid">
                <article class="student-certificate-card">
                    <span class="app-skeleton" style="height: 220px; border-radius: 8px;"></span>
                    <span class="app-skeleton u-mt-4" style="height: 24px;"></span>
                    <span class="app-skeleton u-mt-4"></span>
                </article>
            </div>
        </main>

        <aside class="student-certificate-side">
            <article class="lms-workspace-card student-certificate-side-card student-certificate-reveal" data-certificate-reveal>
                <div class="lms-workspace-section-head">
                    <div>
                        <p class="lms-workspace-kicker">Latest</p>
                        <h2>Chứng chỉ mới nhất</h2>
                    </div>
                </div>

                <div class="student-certificate-spotlight" id="studentCertificateSpotlight">
                    <div class="app-loading">
                        <span class="app-spinner" aria-hidden="true"></span>
                        <span>Đang tải chứng chỉ mới nhất...</span>
                    </div>
                </div>
            </article>
        </aside>
    </section>
</section>

@section Scripts {
    <script src="~/js/pages/student-certificate-list.js" asp-append-version="true"></script>
}
