@{
    ViewData["Title"] = "Chứng chỉ";
}

<div class="page-header">
    <div class="page-header-main">
        <nav class="page-breadcrumb" aria-label="Breadcrumb">
            <a asp-area="" asp-controller="Home" asp-action="Index" data-i18n="certificates.listPage.breadcrumbHome">Trang chủ</a>
            <span>/</span>
            <span data-i18n="certificates.listPage.breadcrumbCertificates">Chứng chỉ</span>
        </nav>
        <h1 class="page-title" data-i18n="certificates.listPage.title">Chứng chỉ</h1>
        <p class="page-muted u-mb-0" data-i18n="certificates.listPage.subtitle">Xem các chứng chỉ đã đạt được và thực hiện xem trước/tải xuống.</p>
    </div>
</div>

<section class="student-certificate-banner app-animate-slide-up">
    <div class="image-slot image-slot-banner image-slot-certificate" data-image-label="Certificate banner 1200x220">
        <img src="~/images/graduation-success.jpg" alt="" aria-hidden="true" />
    </div>
</section>

<section class="page-grid page-grid-3 u-mb-4 app-animate-stagger" aria-label="Certificate summary">
    <article class="app-card app-card-clickable">
        <div class="app-card-body app-metric">
            <div>
                <p class="app-metric-label" data-i18n="certificates.listPage.metricTotal">Tổng chứng chỉ</p>
                <p class="app-metric-value" data-certificate-metric="total">--</p>
            </div>
            <span class="app-metric-icon" aria-hidden="true"><i class="bi bi-award"></i></span>
        </div>
    </article>
    <article class="app-card app-card-clickable">
        <div class="app-card-body app-metric">
            <div>
                <p class="app-metric-label" data-i18n="certificates.listPage.metricLatest">Cấp gần nhất</p>
                <p class="app-metric-value" data-certificate-metric="latest">--</p>
            </div>
            <span class="app-metric-icon" aria-hidden="true"><i class="bi bi-calendar-check"></i></span>
        </div>
    </article>
    <article class="app-card app-card-clickable">
        <div class="app-card-body app-metric">
            <div>
                <p class="app-metric-label" data-i18n="certificates.listPage.metricAvailable">Có thể tải</p>
                <p class="app-metric-value" data-certificate-metric="available">--</p>
            </div>
            <span class="app-metric-icon" aria-hidden="true"><i class="bi bi-download"></i></span>
        </div>
    </article>
</section>

<section class="app-card">
    <div class="app-card-header">
        <div class="admin-card-header-row">
            <div>
                <h2 class="app-card-title" data-i18n="certificates.listPage.cardTitleHistory">Danh sách chứng chỉ</h2>
                <p class="app-card-subtitle" data-i18n="certificates.listPage.cardSubtitleHistory">Chứng chỉ được tải từ dữ liệu mô phỏng trong giai đoạn UI này.</p>
            </div>
            <span class="app-badge app-badge-info" data-certificate-count data-i18n="certificates.listPage.records">-- bản ghi</span>
        </div>
    </div>

    <div class="app-card-body">
        <div class="app-filter-bar admin-user-filter">
            <label class="visually-hidden" for="certificateSearch" data-i18n="certificates.listPage.searchLabel">Tìm kiếm chứng chỉ</label>
            <input class="app-input" id="certificateSearch" type="search" placeholder="Tìm tên bài thi hoặc mã chứng chỉ..." data-certificate-filter="search" data-i18n-placeholder="certificates.listPage.searchPlaceholder" />
            <button class="app-button app-button-secondary" type="button" data-certificate-action="clear-filters" data-i18n="certificates.listPage.clearFilters">Xóa bộ lọc</button>
        </div>

        <div class="certificate-grid u-mt-4" id="certificateGrid">
            <div class="app-card app-skeleton-card">
                <div class="app-card-body">
                    <span class="app-skeleton app-skeleton-image u-mb-4"></span>
                    <div class="app-loading">
                        <span class="app-spinner" aria-hidden="true"></span>
                        <span data-i18n="certificates.listPage.loadingCertificates">Đang tải chứng chỉ...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/pages/student-certificate-list.js" asp-append-version="true"></script>
}
